{% set img = page.media.images|length > 0 ? (page.media.images|first).url : '' %}
{% set img_class = page.header.text_left ? 'right' : 'left' %}
{% set slides = page.content | split("<!-- slide -->")  %}
{% set has_slides = slides | length > 1 %}
{% set randomizer = random() %}

<section class="image-highlight section has-text-white content">
	<h1 class="title img-on-{{ img_class }}">{{ page.header.title }}</h1>
	<div class="img-on-{{ img_class }} image-highlight__content">
		<img src="{{ img }}" alt="Highlight Image" class="{{ img_class }}">
		{% if has_slides %}
			<div class="slides slides-{{ randomizer }}">
				{% for slide in slides %}
					<div id="slide-{{ randomizer }}-{{ loop.index }}" class="slide">
						{{ slide|raw }}
					</div>
				{% endfor %}
			</div>
			<div class="slides__nav has-text-centered">
				{% for slide in slides %}
					<a href="#slide-{{ randomizer }}-{{ loop.index }}"></a>
				{% endfor %}
			</div>
		{% else %}
			{{ page.content|raw }}
			<div class="is-clearfix"></div>
		{% endif %}
	</div>

{% if has_slides %}
	<script>
		const slides = document.querySelectorAll('.image-highlight .slides-{{ randomizer }} .slide');
    const navLinks = document.querySelectorAll('.image-highlight .slides-{{ randomizer }} + .slides__nav a');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => link.classList.remove('active'));
          const activeLink = document.querySelector(`.image-highlight .slides-{{ randomizer }} + .slides__nav a[href="#${entry.target.id}"]`);
          if (activeLink) {
            activeLink.classList.add('active');
          }
        }});
      }, {threshold: 0.3});
      
      slides.forEach(slide => observer.observe(slide));
      </script>
{% endif  %}
</section>
